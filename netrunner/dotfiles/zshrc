# ── Update ───────────────────────────────────────────────────────
_pb_update() {
  local dir="${HOME}/purplebruce"
  [[ -d "$dir" ]] || { echo "[✘] ~/purplebruce not found — run install-arch.sh first"; return 1; }
  echo "[→] Checking for updates..."
  if [[ -d "${dir}/.git" ]]; then
    git -C "$dir" pull origin main && echo "[✔] git pull OK" || echo "[⚠] git pull failed — using local files"
  else
    echo "[⚠] Not a git repo — downloading latest from GitHub..."
    local tmp="/tmp/pb_update_$$"
    mkdir -p "$tmp"
    local url="https://github.com/TAesthetics/purplebruce/archive/refs/heads/main.tar.gz"
    if wget -qO "${tmp}/pb.tar.gz" "$url" 2>/dev/null || \
       python3 -c "import urllib.request; urllib.request.urlretrieve('${url}', '${tmp}/pb.tar.gz')" 2>/dev/null; then
      local bak="${dir}.bak.$(date +%s)"
      mv "$dir" "$bak"
      mkdir -p "$dir"
      tar -xzf "${tmp}/pb.tar.gz" -C "$dir" --strip-components=1
      rm -rf "$tmp"
      echo "[✔] Updated — old backup: $(basename $bak)"
    else
      rm -rf "$tmp"
      echo "[✘] Download failed — check internet"
      return 1
    fi
  fi
  echo "[→] npm install..."
  npm install --prefix "$dir" --silent
  echo "[→] Deploying dotfiles..."
  bash "${dir}/netrunner/dotfiles/install.sh"
  echo "[✔] Done — run: exec zsh"
}
alias pbupdate='_pb_update'
alias update='_pb_update'

