# zshrc Configuration

# Enable Oh-My-Zsh and Powerlevel10k theme
export ZSH="$HOME/.oh-my-zsh"
zsh
source $ZSH/oh-my-zsh.sh
source $ZSH/themes/powerlevel10k/powerlevel10k.zsh-theme

# Sticky MOTD header
PROMPT='\e[1;35mWelcome to your Cyberpunk Terminal!\e[0m
'  # Adds a sticky header

# Real-time clock display
precmd() { echo -ne "\e[1;32m$(date +'%H:%M:%S') \e[0m"; }

# Zsh autosuggestions with cyan colors
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=cyan'
source $ZSH/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

# Syntax highlighting
source $ZSH/plugins/syntax-highlighting/syntax-highlighting.zsh

# FZF integration with cyberpunk colors
export FZF_DEFAULT_OPTS='--color=fg:#00ffcc,bg:#2c3e50,header:#ff79c6,prompt:#50fa7b,info:#bd93f9,marker:#ffb86c'

# Zoxide smart cd
eval "$(zoxide init zsh)"

# Git aliases
alias gs='git status'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias ga='git add'
alias gc='git commit'

# Dev/Pentest aliases
alias pb='your_pb_command'
alias pb-status='your_pb_status_command'
alias pb-logs='your_pb_logs_command'

# Cursor settings
echo -e '\033[12;35m'; # Pink blinking cursor via OSC 12

# Non-blocking package updates
alias update='(sudo apt update && sudo apt upgrade -y) &'

# Command execution timing
preexec() { SECONDS=0; }
# Command duration display
precmd() { echo "Execution time: $SECONDS seconds"; }

# Git status awareness
setopt PROMPT_SUBST
function git_status() {
  if [ -n "$(git status --porcelain)" ]; then
    echo -e "\e[1;31m*\e[0m" # Red asterisk if there are changes
  fi
}

# Weather/IP/Ports utilities
alias weather='curl wttr.in'
alias ip='curl ipinfo.io/ip'
alias ports='netstat -tuln'

# Performance tuning for sub-300ms startup
# Add necessary optimizations here based on your system

# Precmd hooks for persistent system info display
precmd() { echo "System: $(uname -a) | Uptime: $(uptime -p)"; }