# Enhanced Cyberpunk Zsh Configuration

# Oh-My-Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
plugins=(git fzf zoxide)

# Aliases
alias pb='your purple bruce command'
alias pb-status='your pb status command'
alias pb-logs='your pb logs command'
alias gs='git status'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias ga='git add'
alias gc='git commit'
alias gco='git checkout'
alias gb='git branch'

# Directory Navigation
alias ll='ls -la'
alias la='ls -A'
alias lt='ls -lt'

# System Utilities
alias ports='your ports command'
alias myip='your ip command'
alias weather='your weather command'
alias please='your please command'

# MOTD header
if [ -f "$HOME/motd.sh" ]; then
    bash "$HOME/motd.sh"
fi

# Real-time HH:MM:SS clock in right prompt
POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS=(time)

# Optimize performance
export DISABLE_AUTO_TITLE="true"

# Syntax highlighting
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main
    git
    command
    alias
    builtin
    function)
ZSH_HIGHLIGHT_STYLES[command]='cyan'
ZSH_HIGHLIGHT_STYLES[alias]='purple'
ZSH_HIGHLIGHT_STYLES[builtin]='yellow'
ZSH_HIGHLIGHT_STYLES[function]='pink'

# FZF Colour Scheme
export FZF_DEFAULT_OPTS="--color=bg+:cyan,fg:white"

# Show command execution timing
ZSH_COMMAND_EXECUTION_TIME="500"

# Blinking cursor
printf '\e[?12;2;10;5h'

# Disable configuration wizard
DISABLE_ZSH_COMPLTION_WIZARD="true"