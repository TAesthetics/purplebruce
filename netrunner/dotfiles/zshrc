# Enhanced Cyberpunk Zsh Configuration

# Sticky MOTD Header System
function motd {
    echo "Welcome to the Cyberpunk Terminal!"
    echo "============================"
}
precmd() { motd; }

# Live Clock Display
function clock {
    echo -n "\[\e[38;5;14m\]$(date +'%H:%M:%S')\[\e[0m\] "
}

# Enhanced Alias System
alias ll='ls -la'
alias g='git'
# Add more aliases as needed

#fzf integration
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Zoxide Smart CD
eval "
  _zoxide() {
    zoxide query "$@"
  }
"

# Syntax Highlighting
source $ZSH/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Autosuggestions with Cyberpunk Colors
source $ZSH/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

# Pink Blinking Cursor via OSC 12
echo '\[\e[5m\]'

# Git-aware Prompt Optimization
setopt prompt_subst
autoload -Uz vcs_info
precmd() { vcs_info };
setopt prompt_subst
PROMPT='%F{pink}%n@%m %F{cyan}%~ %F{yellow}[$vcs_info_msg_0_] %F{purple}$(clock)%f
$ '

# Intelligent Command Prediction
ZSH_ALIAS_ENABLE='yes'

# Performance Tuning for <300ms Startup
ZSH_DISABLE_COMPFIX=true

# Display Info Before Command Prompt
precmd() {
    echo "\[\e[35m\]$(date +'%Y-%m-%d %H:%M:%S')\[\e[0m\]";
}