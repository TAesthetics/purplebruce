#!/usr/bin/env bash
# TERTRATRONIC RIPPLER v6.0 — TIER 5 — STUFE 2
# Purple Bruce NetRunner CLI — Full-Stack Cyberdeck Tool

set -uo pipefail

# ─── ANSI PALETTE ──────────────────────────────────────────────────────────
R='\033[0;31m';  G='\033[0;32m';  Y='\033[0;33m';  C='\033[0;36m'
M='\033[0;35m';  W='\033[0;37m';  K='\033[1;30m'
BR='\033[1;31m'; BG='\033[1;32m'; BY='\033[1;33m'; BC='\033[1;36m'
BM='\033[1;35m'; BW='\033[1;37m'; DM='\033[2m';    RS='\033[0m'
BLI='\033[5m'

PB_PORT="${PURPLEBRUCE_PORT:-3000}"
PB_DIR="${PURPLEBRUCE_DIR:-$HOME/purplebruce}"
PB_LOG="${HOME}/.purplebruce/audit.log"

# ─── BANNER ────────────────────────────────────────────────────────────────
banner() {
  clear
  echo -e "${BM}"
  echo '  ███╗   ██╗███████╗████████╗██████╗ ██╗   ██╗███╗   ██╗███╗   ██╗███████╗██████╗ '
  echo '  ████╗  ██║██╔════╝╚══██╔══╝██╔══██╗██║   ██║████╗  ██║████╗  ██║██╔════╝██╔══██╗'
  echo '  ██╔██╗ ██║█████╗     ██║   ██████╔╝██║   ██║██╔██╗ ██║██╔██╗ ██║█████╗  ██████╔╝'
  echo '  ██║╚██╗██║██╔══╝     ██║   ██╔══██╗██║   ██║██║╚██╗██║██║╚██╗██║██╔══╝  ██╔══██╗'
  echo '  ██║ ╚████║███████╗   ██║   ██║  ██║╚██████╔╝██║ ╚████║██║ ╚████║███████╗██║  ██║'
  echo '  ╚═╝  ╚═══╝╚══════╝   ╚═╝   ╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═══╝╚═╝  ╚═══╝╚══════╝╚═╝  ╚═╝'
  echo -e "${DM}${C}  TERTRATRONIC RIPPLER v6.0  ·  TIER 5  ·  STUFE 2  ·  PURPLEBRUCE GRID${RS}"
  echo -e "${K}  ══════════════════════════════════════════════════════════════════════════${RS}"
}

# ─── HELPERS ───────────────────────────────────────────────────────────────
ok()   { echo -e "  ${BG}✔${RS}  ${C}${1}${RS}"; }
fail() { echo -e "  ${BR}✘${RS}  ${DM}${1}${RS}"; }
warn() { echo -e "  ${BY}⚠${RS}  ${Y}${1}${RS}"; }
info() { echo -e "  ${BC}→${RS}  ${W}${1}${RS}"; }
fix()  { echo -e "  ${BM}⟳${RS}  ${M}${1}${RS}"; }
hr()   { echo -e "  ${K}────────────────────────────────────────${RS}"; }
section() { echo; hr; echo -e "  ${BM}${1}${RS}"; hr; }

api() { curl -sf --max-time 5 "http://localhost:${PB_PORT}${1}" 2>/dev/null || echo ""; }

# ─── DOCTOR ────────────────────────────────────────────────────────────────
cmd_doctor() {
  local issues=0

  section "ENVIRONMENT"
  local platform="linux"
  if [ -f /etc/kali-release ] || grep -qi "kali" /etc/os-release 2>/dev/null; then
    platform="kali"
    ok "Kali Linux detected ($(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 || echo Kali))"
    if [ -d /data/nhsystem ] || [ "${NETHUNTER:-}" = "1" ]; then
      ok "NetHunter Full Rootless environment"
    elif [ -n "${TERMUX_VERSION:-}" ] || [ -d /data/data/com.termux ]; then
      ok "NetHunter via Termux proot"
    fi
  elif [ -f /etc/arch-release ] || grep -qi "arch" /etc/os-release 2>/dev/null; then
    platform="arch"
    if grep -qi "blackarch" /etc/pacman.conf 2>/dev/null; then
      ok "BlackArch Linux detected"
    else
      ok "Arch Linux detected"
      info "Add BlackArch repos: curl -fsSL https://blackarch.org/strap.sh | bash"
    fi
  elif [ -n "${TERMUX_VERSION:-}" ] || [ -d /data/data/com.termux ]; then
    platform="termux"
    ok "Termux detected"
    if command -v proot-distro >/dev/null 2>&1; then
      ok "proot-distro installed"
      if proot-distro list 2>/dev/null | grep -qi "kali.*installed"; then
        ok "Kali proot: installed"
      elif proot-distro list 2>/dev/null | grep -qi "archlinux.*installed"; then
        ok "Arch proot: installed"
      elif proot-distro list 2>/dev/null | grep -qi "ubuntu.*installed"; then
        ok "Ubuntu proot: installed"
      else
        fail "No proot distro installed"
        fix "Tip: proot-distro install archlinux  OR  proot-distro install kali"
        issues=$(( issues + 1 ))
      fi
    else
      fail "proot-distro missing"
      fix "Running: pkg install proot-distro"
      pkg install proot-distro -y 2>&1 | tail -2 && ok "proot-distro installed" || { warn "Install failed"; issues=$(( issues + 1 )); }
    fi
  else
    ok "Linux environment ($(uname -s) $(uname -r | cut -d- -f1))"
  fi

  section "RUNTIME"
  if command -v node >/dev/null 2>&1; then
    ok "node $(node --version 2>/dev/null || echo '?')"
  else
    fail "Node.js not found"
    case "$platform" in
      kali)  info "Fix: corepack enable  OR  apt install -y nodejs npm" ;;
      arch)  info "Fix: pacman -S nodejs npm" ;;
      *)     info "Fix: pkg install nodejs  OR  nvm install 20" ;;
    esac
    issues=$(( issues + 1 ))
  fi
  if command -v npm >/dev/null 2>&1; then
    ok "npm $(npm --version 2>/dev/null || echo '?')"
  else
    fail "npm not found"; issues=$(( issues + 1 ))
  fi
  if [ -d "${PB_DIR}/node_modules" ]; then
    ok "node_modules present"
  else
    fail "node_modules missing"
    fix "Running: npm install"
    (cd "${PB_DIR}" && npm install 2>&1 | tail -2) && ok "dependencies installed" || { warn "npm install failed"; issues=$(( issues + 1 )); }
  fi

  section "SERVER"
  local srv_pid; srv_pid=$(pgrep -f "node server.js" 2>/dev/null | head -1 || echo "")
  if [ -n "$srv_pid" ]; then
    ok "server process  PID ${srv_pid}"
  else
    fail "server not running"
    info "start with:  netrunner start   OR   cd ${PB_DIR} && npm start"
    issues=$(( issues + 1 ))
  fi
  local status_json; status_json=$(api "/api/status")
  if echo "$status_json" | grep -q '"version"' 2>/dev/null; then
    ok "HTTP :${PB_PORT} responding"
    local prov; prov=$(echo "$status_json" | grep -o '"provider":"[^"]*"' | cut -d'"' -f4 2>/dev/null || echo "?")
    info "active provider: ${prov}"
  else
    fail "HTTP :${PB_PORT} unreachable"
    issues=$(( issues + 1 ))
  fi

  section "DATABASE"
  if [ -f "${PB_DIR}/purplebruce.db" ]; then
    local db_sz; db_sz=$(du -h "${PB_DIR}/purplebruce.db" 2>/dev/null | cut -f1 || echo "?")
    ok "purplebruce.db  (${db_sz})"
  else
    warn "DB not found — server creates it automatically on first start"
  fi
  local log_dir; log_dir=$(dirname "${PB_LOG}")
  if [ -d "$log_dir" ]; then
    ok "log dir  ~/.purplebruce/"
  else
    fix "Creating ~/.purplebruce/"
    mkdir -p "$log_dir" && ok "log dir created"
  fi
  if [ -f "${PB_LOG}" ]; then
    local lc; lc=$(wc -l < "${PB_LOG}" 2>/dev/null || echo "0")
    ok "audit.log  (${lc} entries)"
  else
    info "audit.log not yet created (normal on fresh install)"
  fi

  section "AI PROVIDERS"
  local providers_json; providers_json=$(api "/api/providers")
  if [ -n "$providers_json" ]; then
    local grok_ok;   grok_ok=$(echo "$providers_json"   | grep -c '"grokHasKey":true'   2>/dev/null || echo "0")
    local venice_ok; venice_ok=$(echo "$providers_json" | grep -c '"veniceHasKey":true' 2>/dev/null || echo "0")
    local gemini_ok; gemini_ok=$(echo "$providers_json" | grep -c '"geminiHasKey":true' 2>/dev/null || echo "0")
    local groq_ok;   groq_ok=$(echo "$providers_json"   | grep -c '"groqHasKey":true'   2>/dev/null || echo "0")
    [ "$grok_ok"   -gt 0 ] && ok   "⚡ Grok    key: configured"                    || { warn "⚡ Grok key missing  — Settings → xai-..."; issues=$(( issues + 1 )); }
    [ "$venice_ok" -gt 0 ] && ok   "🔮 Venice  key: configured"                    || info "🔮 Venice: not set (optional — redteam auto-routing)"
    [ "$gemini_ok" -gt 0 ] && ok   "✨ Gemini  key: configured"                    || info "✨ Gemini: not set (free at aistudio.google.com)"
    [ "$groq_ok"   -gt 0 ] && ok   "🎤 Groq    key: configured (Whisper STT)"     || info "🎤 Groq: not set (optional — free STT at console.groq.com)"
  else
    warn "Server offline — cannot verify AI keys"
    info "Set keys at: http://localhost:${PB_PORT}"
  fi

  section "TOOLS"
  local essential="curl jq tmux git bash"
  for t in $essential; do
    command -v "$t" >/dev/null 2>&1 && ok "$t" || { fail "$t missing"; issues=$(( issues + 1 )); }
  done
  echo
  local sec_tools="nmap nikto sqlmap ffuf gobuster hydra whatweb masscan"
  if [ "$platform" = "arch" ]; then
    info "BlackArch / Arch tools:"
    for t in $sec_tools; do
      command -v "$t" >/dev/null 2>&1 && ok "  $t" || warn "  $t not found  (pacman -S $t)"
    done
  else
    info "Kali tools:"
    for t in $sec_tools; do
      command -v "$t" >/dev/null 2>&1 && ok "  $t" || warn "  $t not found  (apt install $t)"
    done
  fi

  echo; hr
  if [ "$issues" -eq 0 ]; then
    echo -e "  ${BG}[ALL CLEAR]${RS}  ${G}Cyberdeck is fully operational — READY${RS}"
  else
    echo -e "  ${BY}[${issues} ISSUES]${RS}  ${Y}See above for repair actions${RS}"
  fi
  echo
}

# ─── DECK ──────────────────────────────────────────────────────────────────
cmd_deck() {
  echo -e "  ${BM}┌───────────────────────────────────────────────────────────────────────┐${RS}"
  echo -e "  ${BM}│${RS}  ${BC}CYBERDECK STATUS${RS}  ${DM}— TERTRATRONIC RIPPLER TIER 5 — PURPLEBRUCE v6.0${RS}  ${BM}│${RS}"
  echo -e "  ${BM}└───────────────────────────────────────────────────────────────────────┘${RS}"

  section "SYSTEM"
  echo -e "  ${C}user    ${BW}${USER:-unknown}${RS}"
  echo -e "  ${C}host    ${BW}$(hostname 2>/dev/null || echo n/a)${RS}"
  echo -e "  ${C}kernel  ${BW}$(uname -r 2>/dev/null || echo n/a)${RS}"
  echo -e "  ${C}arch    ${BW}$(uname -m 2>/dev/null || echo n/a)${RS}"
  echo -e "  ${C}uptime  ${BW}$(uptime -p 2>/dev/null || uptime 2>/dev/null || echo n/a)${RS}"
  echo -e "  ${C}shell   ${BW}${SHELL:-bash}${RS}"

  section "MEMORY"
  if command -v free >/dev/null 2>&1; then
    local mem_total; mem_total=$(free -m 2>/dev/null | awk '/Mem/{print $2}' || echo "0")
    local mem_used;  mem_used=$(free -m  2>/dev/null | awk '/Mem/{print $3}' || echo "0")
    local mem_pct;   mem_pct=$(awk "BEGIN{if(${mem_total}>0)printf \"%.0f\", ${mem_used}/${mem_total}*100;else print 0}" 2>/dev/null || echo "0")
    local bar="" i
    for i in $(seq 1 20); do
      [ "$i" -le "$(( mem_pct / 5 ))" ] && bar+="${BR}█${RS}" || bar+="${K}░${RS}"
    done
    echo -e "  ${C}ram     ${RS}[${bar}] ${BY}${mem_pct}%${RS}  (${mem_used} / ${mem_total} MB)"
  else
    echo -e "  ${C}ram     ${DM}n/a${RS}"
  fi

  section "GRID"
  local ip; ip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "n/a")
  echo -e "  ${C}local   ${BW}${ip}${RS}"
  local status_json; status_json=$(api "/api/status")
  if echo "$status_json" | grep -q '"version"' 2>/dev/null; then
    local prov; prov=$(echo "$status_json" | grep -o '"provider":"[^"]*"' | cut -d'"' -f4 2>/dev/null || echo "?")
    local soc;  soc=$(echo  "$status_json" | grep -o '"socRunning":[^,}]*'  | cut -d: -f2 2>/dev/null || echo "false")
    echo -e "  ${C}server  ${BG}ONLINE :${PB_PORT}${RS}"
    echo -e "  ${C}ai      ${BM}${prov^^}${RS}  ${DM}(active provider)${RS}"
    [ "$soc" = "true" ] \
      && echo -e "  ${C}soc     ${BC}ACTIVE${RS}  ${DM}(blue team monitoring)${RS}" \
      || echo -e "  ${C}soc     ${K}OFFLINE${RS}"
  else
    echo -e "  ${C}server  ${BR}OFFLINE${RS}  ${DM}→  netrunner start${RS}"
  fi

  section "PROCESSES"
  local srv_pid; srv_pid=$(pgrep -f "node server.js" 2>/dev/null | head -1 || echo "")
  [ -n "$srv_pid" ] \
    && echo -e "  ${C}pb-srv  ${BG}PID ${srv_pid}${RS}" \
    || echo -e "  ${C}pb-srv  ${BR}not running${RS}"
  local tmux_s; tmux_s=$(tmux ls 2>/dev/null | wc -l || echo "0")
  echo -e "  ${C}tmux    ${BW}${tmux_s} session(s)${RS}"
  local providers_json; providers_json=$(api "/api/providers")
  if [ -n "$providers_json" ]; then
    local route_rt; route_rt=$(echo "$providers_json" | grep -o '"redteam":"[^"]*"' | cut -d'"' -f4 2>/dev/null || echo "?")
    echo -e "  ${C}routing ${DM}redteam→${RS}${BM}${route_rt^^}${RS}  ${DM}reason→${RS}${BM}GROK${RS}"
  fi

  section "TIER 5 FEATURES"
  echo -e "  ${BG}✔${RS}  ${C}Multi-provider AI router${RS}    ${DM}Grok / Venice / Gemini${RS}"
  echo -e "  ${BG}✔${RS}  ${C}Smart task routing${RS}          ${DM}redteam→Venice, reasoning→Grok, fallback→Gemini${RS}"
  echo -e "  ${BG}✔${RS}  ${C}Voice v2${RS}                    ${DM}PTT + Groq Whisper STT + Edge Neural TTS (free)${RS}"
  echo -e "  ${BG}✔${RS}  ${C}SOC analyst${RS}                 ${DM}blue team auto-respond + forensics${RS}"
  echo -e "  ${BG}✔${RS}  ${C}Black Ice${RS}                   ${DM}MITRE ATT&CK real execution${RS}"
  echo -e "  ${BG}✔${RS}  ${C}Autonomous agent${RS}            ${DM}no approval, runs until done${RS}"
  echo -e "  ${BG}✔${RS}  ${C}Latency display${RS}             ${DM}real-time provider response time${RS}"
  echo
}

# ─── OVERCLOCK ─────────────────────────────────────────────────────────────
cmd_overclock() {
  echo
  echo -e "  ${BR}${BLI}⚡⚡⚡  OVERCLOCK ACTIVE — BRAIN DAMAGE RISK  ⚡⚡⚡${RS}"
  echo
  echo -e "  ${BR}WARNING: Pushing neural interface beyond rated limits.${RS}"
  echo -e "  ${BY}Stability: COMPROMISED  │  Heat: CRITICAL  │  Sanity: OPTIONAL${RS}"
  echo -e "  ${DM}${C}Hold on, choom. This is gonna hurt.${RS}"
  echo

  local total=90
  local start_ts; start_ts=$(date +%s)
  local glitch='▓▒░▄▀█■□▪▫'

  while true; do
    local now_ts; now_ts=$(date +%s)
    local elapsed=$(( now_ts - start_ts ))
    local remaining=$(( total - elapsed ))
    [ "$remaining" -le 0 ] && break

    local pct=$(( elapsed * 100 / total ))
    local filled=$(( pct / 5 ))
    local bar="" i
    for i in $(seq 1 20); do
      [ "$i" -le "$filled" ] && bar+="${BR}█${RS}" || bar+="${K}░${RS}"
    done

    local gc; gc="${glitch:$(( RANDOM % ${#glitch} )):1}"
    printf "\r  ${BM}OC${RS} [${bar}] ${BY}%3d%%${RS}  ${BR}%02d:%02d${RS}  ${K}%s${RS}  " \
      "$pct" "$(( remaining / 60 ))" "$(( remaining % 60 ))" "$gc"
    sleep 0.4
  done

  echo
  echo
  echo -e "  ${BY}[ OVERCLOCK COMPLETE — INITIATING COOLDOWN ]${RS}"
  echo

  local row
  for row in $(seq 1 5); do
    local line="" j
    for j in $(seq 1 48); do
      local ci=$(( RANDOM % ${#glitch} ))
      line+="${glitch:$ci:1}"
    done
    echo -e "  ${K}${line}${RS}"
    sleep 0.08
  done

  echo
  echo -e "  ${BG}[ COOLDOWN COMPLETE — STABILITY NOMINAL ]${RS}"
  echo -e "  ${DM}${C}Neural interface recalibrated. You're welcome.${RS}"
  echo
}

# ─── SCAN ──────────────────────────────────────────────────────────────────
cmd_scan() {
  local target="${1:-}"
  local mode="${2:-STANDARD}"

  if [ -z "$target" ]; then
    echo -e "\n  ${BR}[ERR]${RS}  ${R}usage: netrunner scan <target> [QUICK|STANDARD|FULL|STEALTH]${RS}\n"
    return 1
  fi

  echo -e "\n  ${BC}[RECON]${RS}  ${C}Target: ${BW}${target}${RS}  │  ${C}Mode: ${BY}${mode}${RS}\n"

  if ! command -v curl >/dev/null 2>&1; then
    echo -e "  ${BR}[ERR]${RS} curl not found\n"; return 1
  fi

  if ! api "/api/status" | grep -q '"version"' 2>/dev/null; then
    echo -e "  ${BR}[ERR]${RS}  ${R}Server offline — start with:${RS} netrunner start\n"; return 1
  fi

  echo -e "  ${DM}${C}Connecting to RECON module...${RS}\n"

  local resp
  resp=$(curl -sf --max-time 300 \
    -X POST "http://localhost:${PB_PORT}/api/cli" \
    -H "Content-Type: application/json" \
    -d "{\"cmd\":\"scan\",\"target\":\"${target}\",\"mode\":\"${mode}\"}" 2>/dev/null || echo "")

  if [ -z "$resp" ]; then
    echo -e "  ${BR}[ERR]${RS}  ${R}No response from server.${RS}\n"; return 1
  fi

  if command -v jq >/dev/null 2>&1; then
    echo "$resp" | jq -r '.lines[]?.text // empty' 2>/dev/null | while IFS= read -r line; do
      if   echo "$line" | grep -qiE "error|fail|\[err"; then echo -e "  ${BR}${line}${RS}"
      elif echo "$line" | grep -qiE "open|found|ok\]|pass";  then echo -e "  ${BG}${line}${RS}"
      elif echo "$line" | grep -qiE "warn|risk|alert";        then echo -e "  ${BY}${line}${RS}"
      elif echo "$line" | grep -qiE "recon|\[exit";           then echo -e "  ${BC}${line}${RS}"
      else echo -e "  ${W}${line}${RS}"; fi
    done
  else
    echo "$resp" | grep -o '"text":"[^"]*"' | sed 's/"text":"//;s/"//'
  fi

  echo -e "\n  ${BG}[DONE]${RS}  ${G}Recon complete.${RS}\n"
}

# ─── QUICKHACK ─────────────────────────────────────────────────────────────
cmd_quickhack_menu() {
  local hacks=("PING FLOOD" "MEMORY WIPE" "GHOST THREAD" "DATA LEECH" "SYSTEM CRASH" "NEURAL BURN" "EXIT")
  echo -e "\n  ${BR}[QUICKHACK]${RS}  ${R}Select target protocol:${RS}\n"
  local i=1
  for h in "${hacks[@]}"; do
    [ "$h" = "EXIT" ] && echo -e "  ${K}[$i]${RS}  ${DM}${h}${RS}" || echo -e "  ${BM}[$i]${RS}  ${C}${h}${RS}"
    i=$(( i + 1 ))
  done
  echo
  echo -ne "  ${BY}> select hack: ${RS}"
  read -r choice
  local exit_idx="${#hacks[@]}"
  [[ "$choice" == "$exit_idx" ]] && { echo -e "  ${DM}session terminated.${RS}\n"; return; }
  local idx=$(( choice - 1 ))
  if [[ $idx -ge 0 && $idx -lt $(( exit_idx - 1 )) ]]; then
    echo -e "\n  ${BR}[EXEC]${RS}  ${R}${hacks[$idx]}${RS}  ${DM}initiating...${RS}"
    echo -ne "  ${DM}${C}staging payload...   ${RS}"; sleep 0.15; echo -e "${BG}done${RS}"
    echo -ne "  ${DM}${C}injecting...         ${RS}"; sleep 0.2;  echo -e "${BR}sent${RS}"
    echo -ne "  ${DM}${C}cleanup...           ${RS}"; sleep 0.1;  echo -e "${BG}clean${RS}"
    echo -e "\n  ${BG}[DONE]${RS}  ${G}${hacks[$idx]} deployed.${RS}\n"
  else
    echo -e "  ${BR}[ERR]${RS}  ${R}invalid selection.${RS}\n"
  fi
}

cmd_quickhack_target() {
  local target="$1"
  echo -e "\n  ${BR}[QUICKHACK]${RS}  ${R}targeting: ${BW}${target}${RS}\n"
  echo -ne "  ${DM}${C}scanning target...   ${RS}"; sleep 0.2;  echo -e "${BG}locked${RS}"
  echo -ne "  ${DM}${C}probing ports...     ${RS}"; sleep 0.15; echo -e "${BY}${target}:80,443${RS}"
  echo -ne "  ${DM}${C}staging payload...   ${RS}"; sleep 0.2;  echo -e "${BG}ready${RS}"
  echo -ne "  ${DM}${C}injecting...         ${RS}"; sleep 0.25; echo -e "${BR}payload sent${RS}"
  echo -ne "  ${DM}${C}verifying...         ${RS}"; sleep 0.15; echo -e "${BG}confirmed${RS}"
  echo -e "\n  ${BG}[OK]${RS}  ${G}${target} compromised.${RS}\n"
}

# ─── TEAM ──────────────────────────────────────────────────────────────────
cmd_team() {
  local resp; resp=$(api "/api/team")
  if [ -z "$resp" ]; then
    echo -e "\n  ${BR}[ERR]${RS}  ${R}Server offline — start with: netrunner start${RS}\n"; return 1
  fi

  echo -e "\n  ${BM}┌───────────────────────────────────────────────────────────────┐${RS}"
  echo -e "  ${BM}│${RS}  ${BC}AI TEAM — SELF-HEALING SECURITY COORDINATOR${RS}                  ${BM}│${RS}"
  echo -e "  ${BM}└───────────────────────────────────────────────────────────────┘${RS}"
  echo -e "  ${DM}${C}Three AIs. One team. Discipline over willpower.${RS}\n"

  # Provider status
  echo -e "  ${BM}PROVIDERS${RS}"
  hr
  for provider in grok venice gemini; do
    local label badge
    case "$provider" in
      grok)   label="⚡ GROK-3   "; badge="${BM}" ;;
      venice) label="🔮 VENICE   "; badge="${BR}" ;;
      gemini) label="✨ GEMINI   "; badge="${BC}" ;;
    esac

    if command -v jq >/dev/null 2>&1; then
      local hasKey healthy latency errors status_str
      hasKey=$(echo "$resp"  | jq -r ".providers.${provider}.hasKey // false"  2>/dev/null || echo "false")
      healthy=$(echo "$resp" | jq -r ".providers.${provider}.healthy // null"  2>/dev/null || echo "null")
      latency=$(echo "$resp" | jq -r ".providers.${provider}.latency // null"  2>/dev/null || echo "null")
      errors=$(echo  "$resp" | jq -r ".providers.${provider}.errors  // 0"     2>/dev/null || echo "0")

      if [ "$hasKey" = "false" ]; then
        echo -e "  ${badge}${label}${RS}  ${K}○${RS}  ${DM}no key configured${RS}"
      elif [ "$healthy" = "false" ]; then
        echo -e "  ${badge}${label}${RS}  ${BR}●${RS}  ${R}OFFLINE${RS}  ${DM}(${errors} errors)${RS}"
      else
        local lat_str="${DM}first call pending${RS}"
        [ "$latency" != "null" ] && lat_str="${BG}${latency}ms${RS}"
        echo -e "  ${badge}${label}${RS}  ${BG}●${RS}  ${G}READY${RS}  ${lat_str}"
      fi
    else
      echo -e "  ${badge}${label}${RS}  ${DM}(install jq for details)${RS}"
    fi
  done

  # Heal log
  local heal_count=0
  if command -v jq >/dev/null 2>&1; then
    heal_count=$(echo "$resp" | jq '.healLog | length' 2>/dev/null || echo "0")
  fi
  if [ "$heal_count" -gt 0 ] 2>/dev/null; then
    echo; echo -e "  ${BM}RECENT HEALS${RS}"
    hr
    echo "$resp" | jq -r '.healLog[-4:][] | "  \(.provider | ascii_upcase) → \(.action)"' 2>/dev/null | while IFS= read -r line; do
      echo -e "  ${M}${line}${RS}"
    done
  fi

  # Routing rules
  echo; echo -e "  ${BM}ROUTING RULES${RS}"
  hr
  echo -e "  ${C}redteam     ${BM}→ VENICE${RS}   ${DM}(exploit, pentest, offensive)${RS}"
  echo -e "  ${C}reasoning   ${BM}→ GROK${RS}     ${DM}(code, analysis, chat)${RS}"
  echo -e "  ${C}fallback    ${BM}→ GEMINI${RS}   ${DM}(free tier, long-context, multimodal)${RS}"
  echo -e "  ${C}failover    ${BM}→ AUTO${RS}      ${DM}(next healthy provider in chain)${RS}"
  echo
  echo -e "  ${DM}${Y}Constraint: team acts ONLY on explicit user command.${RS}"
  echo -e "  ${DM}${Y}No uninvited attacks. Authorized redteam scope only.${RS}"
  echo
}

# ─── START (tmux 3-pane layout) ────────────────────────────────────────────
cmd_start() {
  local session="purplebruce"
  if tmux has-session -t "$session" 2>/dev/null; then
    echo -e "\n  ${BY}[WARN]${RS}  Session '${session}' already running — attaching..."
    sleep 0.5
    tmux attach -t "$session"
    return
  fi

  echo -e "\n  ${BM}[START]${RS}  ${M}Launching Purple Bruce 3-pane layout...${RS}\n"

  local cols; cols=$(tput cols  2>/dev/null || echo 220)
  local rows; rows=$(tput lines 2>/dev/null || echo 50)

  tmux new-session -d -s "$session" -x "$cols" -y "$rows"
  tmux rename-window -t "${session}:0" "NETRUNNER"

  # Pane 0: Server
  tmux send-keys -t "${session}:0.0" "cd '${PB_DIR}' && printf '\e[1;35m⚡ STARTING PURPLE BRUCE SERVER...\e[0m\n' && npm start" Enter

  # Pane 1: Logs (bottom strip)
  tmux split-window -t "${session}:0" -v -p 28
  tmux send-keys -t "${session}:0.1" "sleep 3 && printf '\e[1;36m📋 AUDIT LOG\e[0m\n' && tail -f '${PB_LOG}' 2>/dev/null || echo 'Waiting for log...'" Enter

  # Pane 2: Chat CLI (right half of bottom)
  tmux split-window -t "${session}:0.1" -h -p 55
  tmux send-keys -t "${session}:0.2" "sleep 4 && printf '\e[1;35m⬡ LUCY — NETGHOST\e[0m\n' && '${PB_DIR}/purplebruce.sh' tui" Enter

  tmux select-pane -t "${session}:0.0"

  echo -e "  ${BG}[OK]${RS}  ${G}Layout ready — attaching...${RS}\n"
  sleep 0.4
  tmux attach -t "$session"
}

# ─── USAGE ─────────────────────────────────────────────────────────────────
usage() {
  echo -e "\n  ${BC}usage:${RS}  netrunner <command> [args]\n"
  echo -e "  ${BM}doctor${RS}               full health check + auto-repair"
  echo -e "  ${BM}deck${RS}                 cyberdeck status dashboard"
  echo -e "  ${BM}team${RS}                 AI team health + routing status"
  echo -e "  ${BM}overclock${RS}            90s boost timer + cooldown + glitch"
  echo -e "  ${BM}scan <target>${RS}        recon via Purple Bruce API"
  echo -e "  ${BM}scan <t> <mode>${RS}      modes: QUICK  STANDARD  FULL  STEALTH"
  echo -e "  ${BM}quickhack${RS}            interactive hack menu"
  echo -e "  ${BM}quickhack <target>${RS}   direct target injection"
  echo -e "  ${BM}start${RS}                launch tmux 3-pane layout"
  echo
}

# ─── MAIN ──────────────────────────────────────────────────────────────────
banner

case "${1:-}" in
  doctor)    cmd_doctor ;;
  deck)      cmd_deck ;;
  team)      cmd_team ;;
  overclock) cmd_overclock ;;
  scan)      cmd_scan "${2:-}" "${3:-STANDARD}" ;;
  quickhack)
    if [[ -n "${2:-}" ]]; then cmd_quickhack_target "$2"
    else cmd_quickhack_menu; fi ;;
  start)     cmd_start ;;
  *)         usage ;;
esac
